# Terraform provider binaries and plugin cache
.terraform/

# Lock file is safe to commit (pins provider versions) — remove this line if you don't want it tracked
# .terraform.lock.hcl

# State files — contain sensitive infrastructure details, never commit these
*.tfstate
*.tfstate.backup

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log
crash.log
crash.*.log

# Terraform plan output files
*.tfplan

# Lambda build artifacts — generated by build.ps1 / build.sh, not source code
*.zip
